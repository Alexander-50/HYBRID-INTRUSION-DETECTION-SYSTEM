alert icmp any any -> $HOME_NET any (msg:"ICMP FLOOD - echo request burst (>=3500pps)"; itype:8; detection_filter:track by_src, count 3500, seconds 1; classtype:attempted-dos; priority:1; sid:1000003; rev:5; metadata:service icmp;)
#alert icmp any any -> $HOME_NET any (msg:"ICMP FLOOD - rapid echo request burst (>=50pps)"; itype:8; threshold:type threshold, track by_src, count 50, seconds 1; classtype:attempted-dos; priority:1; sid:1000003; rev:4; metadata:service icmp;)
#alert icmp any any -> $HOME_NET any (msg:"ICMP FLOOD - sustained echo requests (50pps x 10s)"; itype:8; threshold:type threshold, track by_src, count 500, seconds 10; classtype:attempted-dos; priority:2; sid:1000102; rev:1; metadata:service icmp;)
