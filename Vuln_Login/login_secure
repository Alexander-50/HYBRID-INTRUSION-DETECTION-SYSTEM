<?php
// ✅ SECURE VERSION - Uses Prepared Statements
session_start();

$host = 'localhost';
$db = 'testlab';
$user = 'root';
$pass = 'root';

$conn = new mysqli($host, $user, $pass, $db);
if ($conn->connect_error) die("Connection failed: " . $conn->connect_error);

$login_error = '';
$login_success = '';

if ($_SERVER['REQUEST_METHOD'] == 'POST' && !isset($_POST['logout'])) {
    $username = $_POST['username'] ?? '';
    $password = $_POST['password'] ?? '';
    $source_ip = $_SERVER['REMOTE_ADDR'];
    
    // ✅ SECURE: Using prepared statements
    $stmt = $conn->prepare("SELECT id, username, email, role FROM users WHERE username = ? AND password = ?");
    $stmt->bind_param("ss", $username, $password);
    $stmt->execute();
    $result = $stmt->get_result();
    
    if ($result->num_rows > 0) {
        $row = $result->fetch_assoc();
        $_SESSION['username'] = $row['username'];
        $_SESSION['role'] = $row['role'];
        $login_success = "✅ Login successful! Welcome, " . htmlspecialchars($row['username']);
        
        $log_stmt = $conn->prepare("INSERT INTO login_attempts (username, password_attempt, source_ip, success) VALUES (?, ?, ?, 1)");
        $log_stmt->bind_param("sss", $username, $password, $source_ip);
        $log_stmt->execute();
        $log_stmt->close();
    } else {
        $login_error = "❌ Invalid credentials";
        
        $log_stmt = $conn->prepare("INSERT INTO login_attempts (username, password_attempt, source_ip, success) VALUES (?, ?, ?, 0)");
        $log_stmt->bind_param("sss", $username, $password, $source_ip);
        $log_stmt->execute();
        $log_stmt->close();
    }
    
    $stmt->close();
}

$is_logged_in = isset($_SESSION['username']);
$current_user = $_SESSION['username'] ?? 'Guest';
$current_role = $_SESSION['role'] ?? 'none';

if (isset($_POST['logout'])) {
    session_destroy();
    header("Location: " . $_SERVER['PHP_SELF']);
    exit;
}
