    $username = $_POST['username'] ?? '';
    $password = $_POST['password'] ?? '';
    $source_ip = $_SERVER['REMOTE_ADDR'];
    
    // ✅ SECURE: Using prepared statements
    $stmt = $conn->prepare("SELECT * FROM users WHERE username = ? AND password = ?");
    $stmt->bind_param("ss", $username, $password);
    $stmt->execute();
    $result = $stmt->get_result();
    
    // Log attempt (also secure)
    $log_stmt = $conn->prepare("INSERT INTO login_attempts (username, password_attempt, source_ip, success) VALUES (?, ?, ?, ?)");
    
    if ($result->num_rows > 0) {
        $row = $result->fetch_assoc();
        $_SESSION['username'] = $row['username'];
        $_SESSION['role'] = $row['role'];
        $success = true;
        $log_stmt->bind_param("sisi", $username, $password, $source_ip, $success);
        $login_success = "Login successful! Welcome, " . htmlspecialchars($row['username']);
    } else {
        $login_error = "Invalid credentials";
        $success = false;
        $log_stmt->bind_param("sisi", $username, $password, $source_ip, $success);
    }
    
    $log_stmt->execute();
    $stmt->close();
    $log_stmt->close();
}

$is_logged_in = isset($_SESSION['username']) ? true : false;
$current_user = $_SESSION['username'] ?? 'Guest';
$current_role = $_SESSION['role'] ?? 'none';

